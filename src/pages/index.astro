---
import { Image } from 'astro:assets';
import landingImage from '../assets/landing-image.jpg';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Thunder Station landing page with venue image."
    />
    <title>Thunder Station</title>
  </head>
  <body>
    <main class="landing" aria-label="Thunder Station">
      <Image
        src={landingImage}
        alt="Thunder Station"
        widths={[640, 960, 1440, 1920, 2560, 3161]}
        sizes="100vw"
        format="webp"
        quality={88}
        priority
        class="landing__image"
      />
      <section class="landing__content" aria-label="Website status">
        <img
          class="brand-logo"
          src="/logos/thunderstation.svg"
          alt="Thunder Station"
          width="340"
          height="122"
        />
        <h1>الموقع قيد التطوير</h1>
        <p class="landing__copy">قريبًا تجربة رقمية جديدة لعشاق الألعاب والإنترنت</p>
        <a class="prices-link" href="/price-menu" lang="ar" dir="rtl">
          عرض قائمة الأسعار
        </a>
        <div class="provider" aria-label="Internet provider">
          <span lang="ar" dir="rtl">مزود الإنترنت</span>
          <img
            class="provider__logo"
            src="/logos/LNET-allred-sized.svg"
            alt="LNET"
          />
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html),
  :global(body) {
    margin: 0;
    min-height: 100%;
    background: #070707;
  }

  .landing {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 100svh;
    overflow: hidden;
    background: #070707;
  }

  .landing::before {
    position: absolute;
    inset: 0;
    z-index: 1;
    content: "";
    background:
      linear-gradient(rgba(0, 255, 213, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 213, 0.06) 1px, transparent 1px),
      radial-gradient(circle at 52% 38%, rgba(0, 255, 213, 0.18), transparent 26rem),
      rgba(0, 0, 0, 0.68);
    background-size: 46px 46px, 46px 46px, auto, auto;
  }

  .landing::after {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    content: "";
    border: 1px solid rgba(0, 255, 213, 0.24);
    box-shadow: inset 0 0 72px rgba(0, 255, 213, 0.1);
  }

  .landing__image {
    display: block;
    width: 100%;
    height: 100svh;
    object-fit: cover;
    object-position: center;
  }

  .landing__content {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 3;
    display: grid;
    justify-items: center;
    width: min(92vw, 820px);
    padding: clamp(22px, 5vw, 52px);
    padding-bottom: clamp(74px, 8vw, 92px);
    transform: translate(-50%, -50%);
    text-align: center;
    color: #f7fff9;
    direction: rtl;
    border: 1px solid rgba(0, 255, 213, 0.2);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.22);
    box-shadow:
      0 0 48px rgba(0, 255, 213, 0.1),
      inset 0 0 42px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(1px);
  }

  .brand-logo {
    width: min(68vw, 300px);
    height: auto;
    margin: 0 0 clamp(18px, 4vw, 28px);
    filter: drop-shadow(0 0 22px rgba(255, 241, 0, 0.32))
      drop-shadow(0 0 34px rgba(0, 255, 213, 0.18));
  }

  h1 {
    margin: 0;
    font-family:
      Tahoma, "Noto Kufi Arabic", "Noto Sans Arabic", Arial, sans-serif;
    font-size: clamp(2.3rem, 8vw, 5.6rem);
    line-height: 1.08;
    letter-spacing: 0;
    text-shadow:
      0 0 20px rgba(0, 255, 213, 0.56),
      0 0 46px rgba(120, 88, 255, 0.34);
  }

  .landing__copy {
    max-width: 36rem;
    margin: 18px 0 0;
    color: rgba(247, 255, 249, 0.84);
    font-family:
      Tahoma, "Noto Kufi Arabic", "Noto Sans Arabic", Arial, sans-serif;
    font-size: clamp(1rem, 3.4vw, 1.35rem);
    line-height: 1.7;
  }

  .prices-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: clamp(20px, 4vw, 32px);
    padding: 0 22px;
    border: 1px solid rgba(0, 255, 213, 0.7);
    border-radius: 6px;
    color: #07100f;
    font-family:
      Tahoma, "Noto Kufi Arabic", "Noto Sans Arabic", Arial, sans-serif;
    font-size: clamp(1rem, 3vw, 1.12rem);
    font-weight: 900;
    text-decoration: none;
    background: #00ffd5;
    box-shadow:
      0 0 22px rgba(0, 255, 213, 0.46),
      inset 0 0 14px rgba(255, 255, 255, 0.24);
  }

  .prices-link:focus-visible,
  .prices-link:hover {
    color: #f7fff9;
    background: rgba(0, 255, 213, 0.12);
    outline: none;
  }

  .provider {
    position: absolute;
    right: clamp(14px, 3vw, 24px);
    bottom: clamp(12px, 2.6vw, 20px);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 7px 9px;
    border: 1px solid rgba(190, 21, 34, 0.5);
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.44);
    box-shadow:
      0 0 18px rgba(190, 21, 34, 0.14),
      inset 0 0 20px rgba(0, 255, 213, 0.06);
  }

  .provider span {
    color: #f7fff9;
    font-family:
      Tahoma, "Noto Kufi Arabic", "Noto Sans Arabic", Arial, sans-serif;
    font-size: clamp(0.68rem, 1.8vw, 0.78rem);
    font-weight: 800;
    white-space: nowrap;
  }

  .provider__logo {
    display: block;
    width: min(22vw, 78px);
    height: auto;
    max-height: 28px;
    object-fit: contain;
    filter: drop-shadow(0 0 10px rgba(190, 21, 34, 0.38));
  }

  @media (max-width: 700px) {
    .landing__image {
      min-height: 100svh;
      height: 100svh;
      object-position: center top;
    }

    .landing::before {
      background:
        linear-gradient(rgba(0, 255, 213, 0.1) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 255, 213, 0.08) 1px, transparent 1px),
        radial-gradient(circle at 50% 34%, rgba(0, 255, 213, 0.2), transparent 18rem),
        rgba(0, 0, 0, 0.72);
      background-size: 34px 34px, 34px 34px, auto, auto;
    }

    .landing__content {
      padding-inline: 18px;
      padding-bottom: 78px;
      width: min(92vw, 520px);
    }

    .brand-logo {
      width: min(74vw, 240px);
    }

    .provider {
      right: 12px;
      bottom: 12px;
      gap: 7px;
      padding: 6px 8px;
    }

    .provider__logo {
      width: 68px;
      max-height: 24px;
    }
  }
</style>
